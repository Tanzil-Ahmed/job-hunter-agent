# Rename this file to .env and fill in your actual keys

ANTHROPIC_API_KEY=your_anthropic_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
EXA_API_KEY=your_exa_api_key_here

# Optional: PostgreSQL connection string (falls back to SQLite if not set)
POSTGRES_URL=postgresql://user:password@localhost:5432/job_hunter

# Optional: candidate contact info (keeps personal data out of config.py)
CANDIDATE_EMAIL=your_email@example.com
CANDIDATE_PHONE=+91-XXXXXXXXXX
CANDIDATE_LINKEDIN=https://linkedin.com/in/your-profile
CANDIDATE_GITHUB=https://github.com/your-username
